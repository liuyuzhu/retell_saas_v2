# ─────────────────────────────────────────────────────────────────────────────
# RetellAI SaaS — Environment Variables
# Copy this file to .env.local and fill in every value marked REQUIRED.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# REQUIRED — Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# REQUIRED — Anon/public key (safe to expose to the browser)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Retell AI ─────────────────────────────────────────────────────────────────
# REQUIRED — API key from https://www.retellai.com/dashboard
RETELL_API_KEY=your_retell_api_key_here

# REQUIRED — Webhook signing secret from Retell dashboard → Webhooks
# Used to verify that webhook events genuinely originate from Retell.
# Generate with: openssl rand -hex 32
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret_here

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED — Secret used to sign JWT session tokens.
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ── Primary (super-admin) account ─────────────────────────────────────────────
# REQUIRED — Email address reserved for the primary administrator.
# This email cannot be used by self-registering users.
PRIMARY_ACCOUNT_EMAIL=admin@yourdomain.com

# REQUIRED — Password for the primary account (used by /api/admin/setup-primary)
PRIMARY_ACCOUNT_PASSWORD=ChangeMe123!

# ── One-time setup endpoints ──────────────────────────────────────────────────
# REQUIRED — Secret required to call /api/admin/init and /api/admin/setup-primary.
# Generate with: openssl rand -base64 32
SETUP_SECRET=your_setup_secret_here

# OPTIONAL — Set to "true" to permanently disable setup endpoints after
# initial configuration (strongly recommended in production).
# SETUP_DISABLED=true

# ── Default admin account (used by /api/admin/init) ──────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Administrator

# ── Email (optional) ──────────────────────────────────────────────────────────
# Leave blank to disable welcome and password-reset emails.

# Provider: Resend (recommended)
RESEND_API_KEY=re_your_resend_api_key

# Provider: SMTP (nodemailer fallback)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@yourdomain.com

# ── Application ───────────────────────────────────────────────────────────────
# REQUIRED — Public URL used for generating password-reset links in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

NODE_ENV=development
